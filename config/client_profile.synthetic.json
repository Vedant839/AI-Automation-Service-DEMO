{
  "client": {
    "name": "AsterLearn Academy",
    "industry": "Online test preparation",
    "timezone": "Asia/Kolkata",
    "primary_contact": "Nisha Rao",
    "technical_contact": "Kabir Menon"
  },
  "support_assistant": {
    "enabled_channels": ["website_chat", "mobile_app_chat", "whatsapp"],
    "handoff_message": "I will connect you with a counselor for this.",
    "blocked_sensitive_topics": [
      "passwords",
      "government_ids",
      "banking_information",
      "full_payment_records"
    ],
    "confidence_threshold": 0.72
  },
  "engagement_rules": {
    "inactive_days_threshold": 7,
    "low_score_threshold_percent": 50,
    "score_decline_threshold_percent": 15,
    "missed_classes_threshold": 2,
    "parent_notification_enabled": true,
    "counselor_escalation_enabled": true
  },
  "teacher_reports": {
    "enabled": true,
    "delivery_time_local": "18:00",
    "delivery_channels": ["email"],
    "include_student_names": false
  },
  "integrations": {
    "crm": {
      "name": "LearnBridge CRM Sandbox",
      "api_base_url": "https://sandbox.learnbridge.example/api",
      "auth_method": "bearer_token"
    },
    "whatsapp": {
      "provider": "MessageNest Sandbox",
      "template_approval_required": true
    },
    "chat_widget": {
      "provider": "ChatDock Demo Widget",
      "embed_location": "student_portal_dashboard"
    }
  }
}
